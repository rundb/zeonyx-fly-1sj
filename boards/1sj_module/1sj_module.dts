 * SPDX-License-Identifier: Apache-2.0
 *
 * 1SJ LoRa Module — STM32L072CZ + SX1262
 * Shell UART: USART2 on PA2 (TX) / PA3 (RX), AF4
 */

/dts-v1/;
#include <st/l0/stm32l072Xz.dtsi>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "1SJ LoRa Module (STM32L072CZ)";
	compatible = "custom,lora-module-l072cz";

	chosen {
		zephyr,console   = &usart2;
		zephyr,shell-uart = &usart2;
		zephyr,sram      = &sram0;
		zephyr,flash     = &flash0;
	};

	/*
	 * SX1262 control signals not part of the SPI bus proper.
	 * Adjust pin numbers to match the actual schematic.
	 *   PB0 = NRESET (active-low)
	 *   PB1 = BUSY   (active-high)
	 */
	zephyr,user {
		sx1262-reset-gpios = <&gpiob 0 GPIO_ACTIVE_LOW>;
		sx1262-busy-gpios  = <&gpiob 1 GPIO_ACTIVE_HIGH>;
	};
};

/* ── Clocks ─────────────────────────────────────────────────────── */

&clk_hsi {
	/* 16 MHz internal RC → PLL → 32 MHz system clock */
	status = "okay";
};

&pll {
	div = <2>;
	mul = <4>;
	clocks = <&clk_hsi>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(32)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
};

/* ── Pinctrl (inline — no external pinctrl DTSI required) ───────── */

&pinctrl {
	usart2_tx_pa2: usart2_tx_pa2 {
		pinmux = <STM32_PINMUX('A', 2, AF4)>;
	};
	usart2_rx_pa3: usart2_rx_pa3 {
		pinmux = <STM32_PINMUX('A', 3, AF4)>;
		bias-disable;
	};

	/* SPI1: PA5=SCK, PA6=MISO, PA7=MOSI  (AF0 on STM32L072) */
	spi1_sck_pa5: spi1_sck_pa5 {
		pinmux = <STM32_PINMUX('A', 5, AF0)>;
		slew-rate = "very-high-speed";
	};
	spi1_miso_pa6: spi1_miso_pa6 {
		pinmux = <STM32_PINMUX('A', 6, AF0)>;
	};
	spi1_mosi_pa7: spi1_mosi_pa7 {
		pinmux = <STM32_PINMUX('A', 7, AF0)>;
		slew-rate = "very-high-speed";
	};
};

/* ── USART2: shell / console on PA2/PA3 ─────────────────────────── */

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* ── SPI1: SX1262 LoRa transceiver ──────────────────────────────── */
/*
 * PA4 = NSS (software CS, active-low)
 * PA5 = SCK, PA6 = MISO, PA7 = MOSI
 * SX1262 uses SPI mode 0, max 16 MHz.
 */

&spi1 {
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;
	status = "okay";

	sx1262: sx1262@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <8000000>;
	};
};

/* ── Flash partitions ────────────────────────────────────────────── */

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* 32 KiB NVS storage at end of 192 KiB flash */
		storage_partition: partition@28000 {
			label = "storage";
			reg = <0x00028000 DT_SIZE_K(32)>;
		};
	};
};
