 *
 * 1SJ LoRa Module — STM32L072CZ + SX1262
 * Shell UART: USART2 on PA2 (TX) / PA3 (RX), AF4
 */

/dts-v1/;
#include <st/l0/stm32l072Xz.dtsi>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "1SJ LoRa Module (STM32L072CZ)";
	compatible = "custom,lora-module-l072cz";

	chosen {
		zephyr,console   = &usart2;
		zephyr,shell-uart = &usart2;
		zephyr,sram      = &sram0;
		zephyr,flash     = &flash0;
	};

	/*
	 * SX1262 control signals (internal, not exposed on module header):
	 *   PB0  = BUSY  (output from SX1262, high while processing)
	 *   PB1  = NRESET (active-low input to SX1262)
	 *   PA15 = DIO1  (IRQ output from SX1262)
	 */
	zephyr,user {
		sx1262-busy-gpios  = <&gpiob 0 GPIO_ACTIVE_HIGH>;
		sx1262-reset-gpios = <&gpiob 1 GPIO_ACTIVE_LOW>;
		sx1262-dio1-gpios  = <&gpioa 15 GPIO_ACTIVE_HIGH>;
	};
};

/* ── Clocks ─────────────────────────────────────────────────────── */

&clk_hsi {
	/* 16 MHz internal RC → PLL → 32 MHz system clock */
	status = "okay";
};

&pll {
	div = <2>;
	mul = <4>;
	clocks = <&clk_hsi>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(32)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
};

/* ── Pinctrl (inline — no external pinctrl DTSI required) ───────── */

&pinctrl {
	usart2_tx_pa2: usart2_tx_pa2 {
		pinmux = <STM32_PINMUX('A', 2, AF4)>;
	};
	usart2_rx_pa3: usart2_rx_pa3 {
		pinmux = <STM32_PINMUX('A', 3, AF4)>;
		bias-disable;
	};

	/* SPI2: PB13=SCK, PB14=MISO, PB15=MOSI  (AF0 on STM32L072) */
	spi2_sck_pb13: spi2_sck_pb13 {
		pinmux = <STM32_PINMUX('B', 13, AF0)>;
		slew-rate = "very-high-speed";
	};
	spi2_miso_pb14: spi2_miso_pb14 {
		pinmux = <STM32_PINMUX('B', 14, AF0)>;
	};
	spi2_mosi_pb15: spi2_mosi_pb15 {
		pinmux = <STM32_PINMUX('B', 15, AF0)>;
		slew-rate = "very-high-speed";
	};
};

/* ── USART2: shell / console on PA2/PA3 ─────────────────────────── */

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* ── SPI2: SX1262 LoRa transceiver ──────────────────────────────── */
/*
 * PB12 = NSS (software CS, active-low)
 * PB13 = SCK, PB14 = MISO, PB15 = MOSI
 * All internal — not exposed on module header.
 */

&spi2 {
	pinctrl-0 = <&spi2_sck_pb13 &spi2_miso_pb14 &spi2_mosi_pb15>;
	pinctrl-names = "default";
	cs-gpios = <&gpiob 12 GPIO_ACTIVE_LOW>;
	status = "okay";

	sx1262: sx1262@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <8000000>;
	};
};

/* ── Flash partitions ────────────────────────────────────────────── */

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* 32 KiB NVS storage at end of 192 KiB flash */
		storage_partition: partition@28000 {
			label = "storage";
			reg = <0x00028000 DT_SIZE_K(32)>;
		};
	};
};
